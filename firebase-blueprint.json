{
  "entities": {
    "User": {
      "title": "User Profile",
      "description": "Employee profile and account information.",
      "type": "object",
      "properties": {
        "userId": { "type": "string" },
        "name": { "type": "string" },
        "email": { "type": "string" },
        "role": { "type": "string", "enum": ["employee", "admin"] },
        "position": { "type": "string" },
        "department": { "type": "string" },
        "employeeId": { "type": "string" },
        "photoUrl": { "type": "string" },
        "idpLink": { "type": "string" },
        "niy": { "type": "string" },
        "nik": { "type": "string" },
        "unit": { "type": "string" },
        "contractStatus": { "type": "string" },
        "entryDate": { "type": "string" },
        "gender": { "type": "string" },
        "birthPlace": { "type": "string" },
        "birthDate": { "type": "string" },
        "education": { "type": "string" },
        "phone": { "type": "string" },
        "domicileAddress": { "type": "string" },
        "residentialAddress": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["userId", "name", "email", "role"]
    },
    "Certification": {
      "title": "Certification",
      "description": "Professional certifications obtained by employees.",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "userId": { "type": "string" },
        "name": { "type": "string", "description": "Nama sertifikasi" },
        "date": { "type": "string", "format": "date", "description": "Tanggal sertifikasi" },
        "photoUrl": { "type": "string", "description": "Foto sertifikat" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["userId", "name", "date"]
    },
    "CareerHistory": {
      "title": "Career History",
      "description": "Employee career progression log.",
      "type": "object",
      "properties": {
        "userId": { "type": "string" },
        "period": { "type": "string" },
        "position": { "type": "string" },
        "unit": { "type": "string" }
      }
    },
    "LeaveEntitlement": {
      "title": "Leave Entitlement",
      "description": "Leave quota for employees.",
      "type": "object",
      "properties": {
        "userId": { "type": "string" },
        "type": { "type": "string" },
        "availableDays": { "type": "number" }
      }
    },
    "AttendanceClaim": {
      "title": "Attendance Claim",
      "description": "Requests for attendance correction.",
      "type": "object",
      "properties": {
        "userId": { "type": "string" },
        "userName": { "type": "string" },
        "date": { "type": "string" },
        "reason": { "type": "string" },
        "status": { "type": "string", "enum": ["pending", "approved", "rejected"] }
      }
    },
    "Attendance": {
      "title": "Attendance Record",
      "description": "Individual daily attendance log.",
      "type": "object",
      "properties": {
        "userId": { "type": "string" },
        "date": { "type": "string", "format": "date" },
        "checkIn": {
          "type": "object",
          "properties": {
            "time": { "type": "string", "format": "date-time" },
            "location": {
              "type": "object",
              "properties": {
                "lat": { "type": "number" },
                "lng": { "type": "number" }
              }
            },
            "address": { "type": "string" }
          }
        },
        "checkOut": {
          "type": "object",
          "properties": {
            "time": { "type": "string", "format": "date-time" },
            "location": {
              "type": "object",
              "properties": {
                "lat": { "type": "number" },
                "lng": { "type": "number" }
              }
            },
            "address": { "type": "string" }
          }
        },
        "status": { "type": "string", "enum": ["present", "late", "absent"] },
        "notes": { "type": "string" }
      },
      "required": ["userId", "date"]
    },
    "RegulationCategory": {
      "title": "Regulation Category",
      "description": "A category of HR regulations.",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "title": { "type": "string" },
        "order": { "type": "number" },
        "items": {
          "type": "array",
          "items": {
            "type": "object",
            "properties": {
              "id": { "type": "string" },
              "title": { "type": "string" },
              "description": { "type": "string" },
              "iconType": { "type": "string", "enum": ["check", "alert"] }
            }
          }
        }
      }
    },
    "FaqCategory": {
      "title": "FAQ Category",
      "description": "A category of help center items.",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "title": { "type": "string" },
        "order": { "type": "number" },
        "items": {
          "type": "array",
          "items": {
            "type": "object",
            "properties": {
              "id": { "type": "string" },
              "question": { "type": "string" },
              "answer": { "type": "string" }
            }
          }
        }
      }
    }
  },
  "firestore": {
    "users/{userId}": {
      "schema": "User",
      "description": "Main user collection containing profile and role."
    },
    "users/{userId}/profile/main": {
      "schema": "User",
      "description": "Detailed profile data."
    },
    "users/{userId}/emergencyContact/main": {
      "schema": "object",
      "description": "Emergency contact info."
    },
    "users/{userId}/careerProgress/{careerId}": {
      "schema": "CareerHistory",
      "description": "Career timeline items."
    },
    "users/{userId}/leaveCycles/{cycleId}": {
      "schema": "object",
      "description": "Leave entitlement cycles."
    },
    "users/{userId}/attendanceClaims/{claimId}": {
      "schema": "AttendanceClaim",
      "description": "Employee attendance claims."
    },
    "users/{userId}/certificates/{certificateId}": {
      "schema": "Certification",
      "description": "Employee certifications."
    },
    "users/{userId}/attendance/{attendanceId}": {
      "schema": "Attendance",
      "description": "Daily attendance logs."
    },
    "dashboardStats/{statId}": {
      "schema": "object",
      "description": "General dashboard statistics."
    },
    "policyCategories/{categoryId}": {
      "schema": "RegulationCategory",
      "description": "HR policy categories."
    },
    "policyItems/{policyId}": {
      "schema": "object",
      "description": "Individual policy items."
    },
    "helpCategories/{categoryId}": {
      "schema": "FaqCategory",
      "description": "Help center categories."
    },
    "faqItems/{faqId}": {
      "schema": "object",
      "description": "Individual FAQ items."
    }
  }
}
