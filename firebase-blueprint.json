{
  "entities": {
    "User": {
      "title": "User Profile",
      "description": "Employee profile and account information.",
      "type": "object",
      "properties": {
        "userId": { "type": "string" },
        "name": { "type": "string" },
        "email": { "type": "string" },
        "role": { "type": "string", "enum": ["employee", "admin"] },
        "position": { "type": "string" },
        "department": { "type": "string" },
        "employeeId": { "type": "string" },
        "photoUrl": { "type": "string" },
        "idpLink": { "type": "string" },
        "niy": { "type": "string" },
        "nik": { "type": "string" },
        "unit": { "type": "string" },
        "contractStatus": { "type": "string" },
        "entryDate": { "type": "string" },
        "gender": { "type": "string" },
        "birthPlace": { "type": "string" },
        "birthDate": { "type": "string" },
        "education": { "type": "string" },
        "phone": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["userId", "name", "email", "role"]
    },
    "Certification": {
      "title": "Certification",
      "description": "Professional certifications obtained by employees.",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "certificationName": { "type": "string" },
        "certificationDate": { "type": "string" },
        "certificateFileUrl": { "type": "string" },
        "certificateFileName": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["certificationName", "certificationDate"]
    },
    "PersonalData": {
      "title": "Personal Data",
      "description": "Detailed personal information.",
      "type": "object",
      "properties": {
        "namaLengkap": { "type": "string" },
        "niy": { "type": "string" },
        "jabatan": { "type": "string" },
        "unit": { "type": "string" },
        "emailOfficial": { "type": "string" },
        "telepon": { "type": "string" },
        "nik": { "type": "string" },
        "npwp": { "type": "string" },
        "gender": { "type": "string" },
        "statusKawin": { "type": "string" },
        "tempatLahir": { "type": "string" },
        "tanggalLahir": { "type": "string" },
        "alamatLengkap": { "type": "string" },
        "tingkatPendidikan": { "type": "string" },
        "institusiJurusan": { "type": "string" },
        "statusKontrak": { "type": "string" },
        "tanggalMasuk": { "type": "string" },
        "bpjsNomor": { "type": "string" },
        "idpLink": { "type": "string" },
        "aksesLevel": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" },
        "updatedAt": { "type": "string", "format": "date-time" }
      }
    },
    "ContactData": {
      "title": "Contact Data",
      "description": "Emergency and contact information.",
      "type": "object",
      "properties": {
        "namaKontak": { "type": "string" },
        "hubungan": { "type": "string" },
        "nomorHp": { "type": "string" },
        "emergencyContact": { "type": "boolean" },
        "updatedAt": { "type": "string", "format": "date-time" }
      }
    },
    "CareerHistory": {
      "title": "Career History",
      "description": "Employee career progression log.",
      "type": "object",
      "properties": {
        "period": { "type": "string" },
        "position": { "type": "string" },
        "unit": { "type": "string" },
        "active": { "type": "boolean" },
        "createdAt": { "type": "string", "format": "date-time" }
      }
    },
    "LeaveEntitlement": {
      "title": "Leave Entitlement",
      "description": "Leave quota for employees.",
      "type": "object",
      "properties": {
        "userId": { "type": "string" },
        "type": { "type": "string" },
        "availableDays": { "type": "number" }
      }
    },
    "AttendanceClaim": {
      "title": "Attendance Claim",
      "description": "Requests for attendance correction.",
      "type": "object",
      "properties": {
        "reason": { "type": "string" },
        "date": { "type": "string" },
        "status": { "type": "string", "enum": ["pending", "approved", "rejected"] },
        "gformLink": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" }
      }
    },
    "Attendance": {
      "title": "Attendance Record",
      "description": "Individual daily attendance log.",
      "type": "object",
      "properties": {
        "userId": { "type": "string" },
        "date": { "type": "string", "format": "date" },
        "checkIn": { "type": "string" },
        "checkOut": { "type": "string" },
        "status": { "type": "string" }
      },
      "required": ["userId", "date"]
    },
    "RegulationCategory": {
      "title": "Regulation Category",
      "description": "A category of HR regulations.",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "title": { "type": "string" },
        "order": { "type": "number" },
        "items": {
          "type": "array",
          "items": {
            "type": "object",
            "properties": {
              "id": { "type": "string" },
              "title": { "type": "string" },
              "description": { "type": "string" },
              "iconType": { "type": "string", "enum": ["check", "alert"] }
            }
          }
        }
      }
    },
    "FaqCategory": {
      "title": "FAQ Category",
      "description": "A category of help center items.",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "title": { "type": "string" },
        "order": { "type": "number" },
        "items": {
          "type": "array",
          "items": {
            "type": "object",
            "properties": {
              "id": { "type": "string" },
              "question": { "type": "string" },
              "answer": { "type": "string" }
            }
          }
        }
      }
    }
  },
  "firestore": {
    "users/{userId}": {
      "schema": "User",
      "description": "User profile documents."
    },
    "users/{userId}/personalData/{dataId}": {
      "schema": "PersonalData",
      "description": "Detailed personal information sub-collection."
    },
    "users/{userId}/contactData/{dataId}": {
      "schema": "ContactData",
      "description": "Emergency and contact information sub-collection."
    },
    "users/{userId}/careerHistory/{historyId}": {
      "schema": "CareerHistory",
      "description": "Employee career progression log sub-collection."
    },
    "users/{userId}/certifications/{certId}": {
      "schema": "Certification",
      "description": "Employee certifications sub-collection."
    },
    "users/{userId}/attendanceClaims/{claimId}": {
      "schema": "AttendanceClaim",
      "description": "Requests for attendance correction sub-collection."
    },
    "attendance/{attendanceId}": {
      "schema": "Attendance",
      "description": "Attendance history records."
    },
    "regulations/{categoryId}": {
      "schema": "RegulationCategory",
      "description": "HR regulations and policies."
    },
    "helpCenter/{categoryId}": {
      "schema": "FaqCategory",
      "description": "Help center and FAQ data."
    }
  }
}
