rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    function isSignedIn() {
      return request.auth != null;
    }

    function isOwner(uid) {
      return isSignedIn() && request.auth.uid == uid;
    }

    function isAdmin() {
      return isSignedIn() && (
        request.auth.token.email.lower() == "maudy@lazuardi.sch.id" ||
        (exists(/databases/$(database)/documents/users/$(request.auth.uid)) && 
         get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == "admin")
      );
    }

    match /users/{userId} {
      allow read, list: if isSignedIn();
      allow create, update: if isSignedIn() && (userId == request.auth.uid || isAdmin());
      allow delete: if isAdmin() || request.auth.token.email.lower() == "maudy@lazuardi.sch.id";

      match /profile/{docId} {
        allow read, list: if isSignedIn();
        allow write: if isSignedIn() && (userId == request.auth.uid || isAdmin());
      }

      match /emergencyContact/{docId} {
        allow read, list: if isSignedIn();
        allow write: if isSignedIn() && (userId == request.auth.uid || isAdmin());
      }

      match /careerProgress/{docId} {
        allow read, list: if isSignedIn();
        allow write: if isSignedIn() && (userId == request.auth.uid || isAdmin());
      }

      match /leaveCycles/{docId} {
        allow read, list: if isSignedIn();
        allow write: if isSignedIn() && (userId == request.auth.uid || isAdmin());
      }

      match /attendanceClaims/{docId} {
        allow read, list, create, update, delete: if isSignedIn();
      }

      match /certificates/{docId} {
        allow read, list: if isSignedIn();
        allow write: if isSignedIn() && (userId == request.auth.uid || isAdmin());
      }

      match /attendance/{docId} {
        allow read, list, create, update, delete: if isSignedIn();
      }
    }

    // Collection Group rules
    match /{path=**}/attendanceClaims/{docId} {
      allow read, list, write: if isSignedIn();
    }

    match /{path=**}/certificates/{docId} {
      allow read, list: if isSignedIn();
    }

    match /{path=**}/careerProgress/{docId} {
      allow read, list: if isSignedIn();
    }

    match /{path=**}/leaveCycles/{docId} {
      allow read, list: if isSignedIn();
    }

    match /dashboardStats/{docId} {
      allow get, list: if isSignedIn();
      allow create, update, delete: if isAdmin();
    }

    match /policyCategories/{docId} {
      allow read: if isSignedIn();
      allow write: if isAdmin();
    }

    match /policyItems/{docId} {
      allow read: if isSignedIn();
      allow write: if isAdmin();
    }

    match /helpCategories/{docId} {
      allow read: if isSignedIn();
      allow write: if isAdmin();
    }

    match /faqItems/{docId} {
      allow read: if isSignedIn();
      allow write: if isAdmin();
    }
  }
}
