rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    function isSignedIn() {
      return request.auth != null;
    }

    function isOwner(uid) {
      return isSignedIn() && request.auth.uid == uid;
    }

    function isAdmin() {
      return isSignedIn() && 
        get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == "admin";
    }

    match /users/{userId} {
      allow read: if isSignedIn() && (userId == request.auth.uid || isAdmin() || resource.data.email == request.auth.token.email);
      allow write: if isSignedIn() && (userId == request.auth.uid || isAdmin());
      allow list: if isSignedIn() && (isAdmin() || request.query.filters.email == request.auth.token.email);

      match /profile/{docId} {
        allow read, write: if isSignedIn() && (userId == request.auth.uid || isAdmin());
      }

      match /emergencyContact/{docId} {
        allow read, write: if isSignedIn() && (userId == request.auth.uid || isAdmin());
      }

      match /careerProgress/{docId} {
        allow read, write: if isSignedIn() && (userId == request.auth.uid || isAdmin());
      }

      match /leaveCycles/{docId} {
        allow read, write: if isSignedIn() && (userId == request.auth.uid || isAdmin());
      }

      match /attendanceClaims/{docId} {
        allow read, create, update, delete: if isSignedIn() && (userId == request.auth.uid || isAdmin());
      }

      match /certificates/{docId} {
        allow read: if isSignedIn() && (userId == request.auth.uid || isAdmin());
        allow write: if isSignedIn() && (userId == request.auth.uid || isAdmin());
      }

      match /attendance/{docId} {
        allow read, create, update, delete: if isSignedIn() && (userId == request.auth.uid || isAdmin());
      }
    }

    // Collection Group rules
    match /{path=**}/attendanceClaims/{docId} {
      allow read, list: if isSignedIn() && (resource.data.userId == request.auth.uid || isAdmin());
    }

    match /{path=**}/certificates/{docId} {
      allow read, list: if isSignedIn() && (resource.data.userId == request.auth.uid || isAdmin());
    }

    match /dashboardStats/{docId} {
      allow get, list: if isSignedIn();
      allow create, update, delete: if isAdmin();
    }

    match /policyCategories/{docId} {
      allow read: if isSignedIn();
      allow write: if isAdmin();
    }

    match /policyItems/{docId} {
      allow read: if isSignedIn();
      allow write: if isAdmin();
    }

    match /helpCategories/{docId} {
      allow read: if isSignedIn();
      allow write: if isAdmin();
    }

    match /faqItems/{docId} {
      allow read: if isSignedIn();
      allow write: if isAdmin();
    }
  }
}
