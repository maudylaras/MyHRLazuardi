rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Helper Functions
    function isSignedIn() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    function isAdmin() {
      return isSignedIn() && (
        request.auth.token.email == 'maudy@lazuardi.sch.id' ||
        exists(/databases/$(database)/documents/admins/$(request.auth.uid))
      );
    }

    function incoming() {
      return request.resource.data;
    }

    function existing() {
      return resource.data;
    }

    function isValidId(id) {
      return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$');
    }

    // Validation Blueprint: User
    function isValidUser(data) {
      return data.keys().hasAll(['userId', 'name', 'email', 'role']) &&
             data.keys().size() <= 40 &&
             (data.userId == request.auth.uid || isAdmin() || data.userId.matches('^mock_.*')) &&
             data.name is string && data.name.size() <= 100 &&
             data.email is string && data.email.size() <= 100 &&
             data.role in ['employee', 'admin'];
    }

    // Validation Blueprint: Attendance
    function isValidAttendance(data) {
      return data.keys().hasAll(['userId', 'date']) &&
             data.keys().size() <= 20 &&
             data.userId == request.auth.uid &&
             data.date is string && data.date.size() == 10 &&
             (data.get('checkIn', null) == null || (
               data.checkIn.time is timestamp &&
               data.checkIn.location.lat is number &&
               data.checkIn.location.lng is number
             )) &&
             (data.get('checkOut', null) == null || (
               data.checkOut.time is timestamp &&
               data.checkOut.location.lat is number &&
               data.checkOut.location.lng is number
             ));
    }

    function isValidFaqCategory(data) {
      return data.keys().hasAll(['id', 'title', 'items', 'order']) &&
             data.id is string && data.id.size() <= 64 &&
             data.title is string && data.title.size() <= 100 &&
             data.items is list && data.items.size() <= 50 &&
             data.order is int;
    }

    function isValidRegulationCategory(data) {
      return data.keys().hasAll(['id', 'title', 'items', 'order']) &&
             data.id is string && data.id.size() <= 64 &&
             data.title is string && data.title.size() <= 100 &&
             data.items is list && data.items.size() <= 50 &&
             data.order is int;
    }

    // Validation Blueprint: Certification
    function isValidCertification(data) {
      return data.keys().hasAll(['certificationName', 'certificationDate', 'createdAt']) &&
             data.certificationName is string && data.certificationName.size() <= 200 &&
             data.certificationDate is string && data.certificationDate.size() <= 64 &&
             (data.get('certificateFileUrl', null) == null || data.certificateFileUrl is string);
    }

    // Validation Blueprint: PersonalData
    function isValidPersonalData(data) {
      return data.keys().size() <= 40;
    }

    // Validation Blueprint: ContactData
    function isValidContactData(data) {
      return data.keys().hasAll(['namaKontak', 'hubungan', 'nomorHp']) &&
             data.namaKontak is string &&
             data.hubungan is string &&
             data.nomorHp is string;
    }

    // Validation Blueprint: CareerHistory
    function isValidCareerHistory(data) {
      return data.keys().hasAll(['period', 'position', 'unit']) &&
             data.period is string &&
             data.position is string &&
             data.unit is string;
    }

    // Validation Blueprint: AttendanceClaim
    function isValidAttendanceClaim(data) {
      return data.keys().hasAll(['reason', 'date', 'status']) &&
             data.reason is string &&
             data.date is string &&
             data.status in ['pending', 'approved', 'rejected'];
    }

    // User Profiles & Sub-collections
    match /users/{userId} {
      allow get: if isSignedIn();
      allow list: if isAdmin();
      allow create: if (isOwner(userId) && isValidUser(incoming())) || isAdmin();
      allow update: if (isOwner(userId) || isAdmin());

      match /{allSubcollections=**} {
        allow read: if isOwner(userId) || isAdmin();
        allow write: if isOwner(userId) || isAdmin();
      }
    }

    // Regulations
    match /regulations/{categoryId} {
      allow read: if isSignedIn();
      allow write: if isAdmin();
    }

    // Help Center
    match /helpCenter/{categoryId} {
      allow read: if isSignedIn();
      allow write: if isAdmin();
    }

    // Attendance Records
    match /attendance/{attendanceId} {
      allow read: if isSignedIn() && (resource == null || resource.data.userId == request.auth.uid || isAdmin());
      allow create: if isSignedIn() && incoming().userId == request.auth.uid;
      allow update: if (isSignedIn() && existing().userId == request.auth.uid) || isAdmin();
    }
    
    // Admins Collection (Read-only for rules)
    match /admins/{adminId} {
      allow read: if isSignedIn();
    }

    // Test Connection
    match /test/connection {
      allow read: if true;
    }

    // Default Deny
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
