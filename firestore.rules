rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    function isSignedIn() {
      return request.auth != null;
    }

    function isVerified() {
      return isSignedIn() && request.auth.token.email_verified == true;
    }

    function isOwner(uid) {
      return request.auth.uid == uid;
    }

    function isAdmin() {
      return isSignedIn()
        && exists(/databases/$(database)/documents/users/$(request.auth.uid))
        && get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == "admin";
    }

    function isValidId(id) {
      return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$');
    }

    function incoming() {
      return request.resource.data;
    }

    match /users/{uid} {
      allow read, write: if isSignedIn() && (isOwner(uid) || isAdmin());

      match /profile/{docId} {
        allow read, write: if isSignedIn() && (isOwner(uid) || isAdmin());
      }

      match /emergencyContact/{docId} {
        allow read, write: if isSignedIn() && (isOwner(uid) || isAdmin());
      }

      match /careerProgress/{docId} {
        allow read, write: if isSignedIn() && (isOwner(uid) || isAdmin());
      }

      match /leaveCycles/{docId} {
        allow read, write: if isSignedIn() && (isOwner(uid) || isAdmin());
      }

      match /attendanceClaims/{docId} {
        allow read, create, update, delete: if isSignedIn() && (isOwner(uid) || isAdmin());
      }

      match /certificates/{docId} {
        allow read, create, update, delete: if isSignedIn() && (isOwner(uid) || isAdmin());
      }

      match /attendance/{docId} {
        allow read, create, update, delete: if isSignedIn() && (isOwner(uid) || isAdmin());
      }
    }

    // Collection Group rule for attendanceClaims
    match /{path=**}/attendanceClaims/{docId} {
      allow list: if isSignedIn() && (isOwner(resource.data.userId) || isAdmin());
    }

    match /dashboardStats/{docId} {
      allow get, list: if isSignedIn();
      allow create, update, delete: if isAdmin();
    }

    match /policyCategories/{docId} {
      allow get, list: if isSignedIn();
      allow create, update, delete: if isAdmin();
    }

    match /policyItems/{docId} {
      allow get, list: if isSignedIn();
      allow create, update, delete: if isAdmin();
    }

    match /helpCategories/{docId} {
      allow get, list: if isSignedIn();
      allow create, update, delete: if isAdmin();
    }

    match /faqItems/{docId} {
      allow get, list: if isSignedIn();
      allow create, update, delete: if isAdmin();
    }
  }
}
